class Solution { // 1. Yahan 'c' laga diya
    public int maxSubArray(int[] nums) {
        int max = Integer.MIN_VALUE;
        int crr = 0;
        
        for(int i = 0; i < nums.length; i++) {
            crr = crr + nums[i];
            
            // Pehle max update karo, taaki agar saare numbers negative hon toh bhi sahi answer aaye
            max = Math.max(crr, max);
            
            if(crr < 0) {
                crr = 0;
            }
        }
        
        return max; // 2. Print karne ke bajay value return kar di
    }
}
